# ── Bază de date ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://medilink_user:medilink_pass@127.0.0.1:5432/medilink

# ── Redis (cozi de sarcini, sesiuni) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generează un secret random: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=schimba-asta-cu-un-string-random-lung
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Groq AI (chat medical + predicție risc) ───────────────────────────────────
# Obține gratuit la: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Criptare date sensibile (FERNET) ─────────────────────────────────────────
# Generează: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── Email SMTP (opțional — lasă gol pentru a dezactiva notificările email) ────
# Exemplu Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465
# Necesită "App Password" din Google Account > Security > 2-Step > App passwords
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MediLink <noreply@medilink.ro>
